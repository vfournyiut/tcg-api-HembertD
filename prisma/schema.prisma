generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PokemonType {
  Normal
  Fire
  Water
  Electric
  Grass
  Ice
  Fighting
  Poison
  Ground
  Flying
  Psychic
  Bug
  Rock
  Ghost
  Dragon
  Dark
  Steel
  Fairy
}

model Card {
  id            Int         @id @default(autoincrement())
  name          String
  hp            Int
  attack        Int
  type          PokemonType
  pokedexNumber Int
  imgUrl        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deckcards     DeckCard[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  decks     Deck[]
}

model Deck {
  id        Int        @id @default(autoincrement())
  name      String
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     DeckCard[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model DeckCard {
  id        Int      @id @default(autoincrement())
  deckId    Int
  cardId    Int
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId])
}

enum RoomStatus {
  WAITING     // En attente d'un second joueur
  IN_PROGRESS // Partie en cours
  FINISHED    // Partie terminée
}

model Room {
  id           Int        @id @default(autoincrement())
  name         String?    // Nom de la room (optionnel)
  hostId       Int        // ID de l'utilisateur host
  hostDeckId   Int        // ID du deck du host
  player2Id    Int?       // ID du second joueur (null si en attente)
  player2DeckId Int?      // ID du deck du second joueur
  status       RoomStatus // État de la room
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
